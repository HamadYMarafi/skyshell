# ─────────────────────────────────────────────────────────────────────────────
# Skyshell — configuration reference
# ─────────────────────────────────────────────────────────────────────────────
# Copy to `.env`  (cp .env.example .env)  and fill in your own values.
#
# Skyshell grew as a set of small services, so not every value is wired through
# a single .env yet — some live directly in the config files under infra/ and
# server/. This file is the single place that lists EVERY value you need to
# choose, and points at the file to edit when it isn't an env var yet.
# See docs/CONFIGURE.md for the "which file, which line" map.
# ─────────────────────────────────────────────────────────────────────────────

# ── Identity / public hostnames ──────────────────────────────────────────────
# The public hostname your Skyshell app answers on (behind Cloudflare Access).
# Used in: infra/cloudflared/config.example.yml, infra/systemd/cockpit-*.service
APP_HOST=skyshell.example.com
# Optional: a hostname for code-server (VS Code in the browser). Leave blank to skip.
CODE_HOST=code.example.com

# ── Cloudflare Tunnel + Access ───────────────────────────────────────────────
# Create the tunnel with `cloudflared tunnel create skyshell` (see docs/DEPLOY.md).
CF_TUNNEL_ID=00000000-0000-0000-0000-000000000000
CF_ACCOUNT_ID=your_cloudflare_account_id
# Your Access team domain, e.g. your-team.cloudflareaccess.com
# Read by server/origin_auth.py as ACCESS_TEAM_DOMAIN.
ACCESS_TEAM_DOMAIN=your-team.cloudflareaccess.com

# ── Server / deploy (only needed if you use tools/deploy.sh from a workstation)─
DEPLOY_USER=ubuntu
DEPLOY_HOST=YOUR_SERVER_IP
SSH_KEY=~/.ssh/your-server.key

# ── Residential proxy (the live-browser's exit IP) ───────────────────────────
# Skyshell routes its live browser through a local forward proxy (tinyproxy on
# 127.0.0.1:8899) whose UPSTREAM is a residential proxy you rent. Put the full
# upstream URL in /etc/residential-proxy.conf on the server (NOT in git).
# See docs/LIVE-BROWSER.md.  Example upstream form:
#   http://USER:PASS@your-residential-exit-host:PORT
RESIDENTIAL_PROXY_UPSTREAM=http://USER:PASS@your-residential-exit-host:PORT
# The local forward-proxy address the browser actually points at (rarely changed):
LOCAL_PROXY_ADDR=127.0.0.1:8899

# ── Alerts (optional) ────────────────────────────────────────────────────────
# server/term-alert.sh pushes to ntfy.sh (no account needed). Pick any unguessable
# topic name. Read from ~/.term-alert-env on the server as ALERT_NTFY_TOPIC.
ALERT_NTFY_TOPIC=skyshell-alerts-change-me
# Optional Discord webhook for the same alerts:
ALERT_DISCORD_WEBHOOK=

# ── Internal ports (defaults — change only if they clash on your box) ─────────
NGINX_APP_PORT=7690       # public app vhost (cloudflared points here)
NGINX_AGENT_PORT=7695     # emergency/agent vhost, SSH-tunnel only, never Access-gated
TTYD_PORT=7681            # ttyd -> tmux "main"
TABS_PORT=7691            # tabs/stats service (TERM_TABS_PORT)
BCTL_PORT=7692            # browser-control service (xdotool bridge)
ORIGIN_AUTH_PORT=7697     # origin-side Access JWT verifier
KASMVNC_PORT=6081         # KasmVNC web/WS for display :99
LOCAL_PROXY_PORT=8899     # tinyproxy -> residential upstream
CDP_PORT=9222             # Chromium remote-debugging (CDP) — drive the live browser
MCP_PORT=8933             # Playwright MCP attached to CDP (point your AI here)
COCKPIT_BRIDGE_PORT=8934  # CDP screencast + control bridge (cockpit v2)
COCKPIT_WEBRTC_PORT=8935  # WebRTC signaling (H.264/Opus live view)
COCKPIT_VHOST_PORT=8080   # standalone cockpit nginx vhost
DISPLAY_NUM=99            # Xvfb virtual display number
